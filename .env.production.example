NODE_ENV=production
PORT=8787
TRUST_PROXY=1
CORS_ORIGINS=https://your-domain.example
REQUEST_SIZE_LIMIT=512kb
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX=90
RATE_LIMIT_MAX_KEYS=10000
SESSION_TTL_MS=86400000
MAX_SESSIONS=2000
# Required in production: bearer token for sensitive routes.
AUTH_TOKEN=
OPENAI_API_KEY=
LLM_API_KEY=
LLM_MODEL=gpt-4o-mini
